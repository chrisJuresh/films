# Copy to  deploy/.env  on the server and fill in (both are OPTIONAL).
# Without them the site still works — typographic posters + full rankings.
# With them you get poster art, backdrops, cast, trailers, and IMDb / Rotten
# Tomatoes / Metacritic ratings.

# TMDB (posters, backdrops, cast photos, trailers) — free key:
#   https://www.themoviedb.org/settings/api   (the v3 "API Key")
TSPDT_TMDB_KEY=

# OMDb (IMDb rating & votes, Rotten Tomatoes, Metacritic, plot) — free tier:
#   http://www.omdbapi.com/apikey.aspx
TSPDT_OMDB_KEY=
