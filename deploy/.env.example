# Copy to deploy/.env on the server and fill in whichever integrations you use.
# Metadata keys are optional. The four Radarr values are optional as a group;
# all four are required to activate the Download button.

# TMDB (posters, backdrops, cast photos, trailers) — free key:
#   https://www.themoviedb.org/settings/api   (the v3 "API Key")
TSPDT_TMDB_KEY=

# OMDb (IMDb rating & votes, Rotten Tomatoes, Metacritic, plot) — free tier:
#   http://www.omdbapi.com/apikey.aspx
TSPDT_OMDB_KEY=

# Radarr. The films compose service joins the existing a3-arr Docker network,
# where the service name "radarr" resolves at http://radarr:7878.
# RADARR_ROOT_FOLDER is the movie path as Radarr sees it, not a films-container
# path. Find the numeric profile id with GET /api/v3/qualityprofile in Radarr.
RADARR_URL=http://radarr:7878
RADARR_API_KEY=
RADARR_ROOT_FOLDER=
RADARR_QUALITY_PROFILE_ID=
