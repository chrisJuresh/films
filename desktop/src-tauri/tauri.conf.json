{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Film Index",
  "version": "0.1.6",
  "identifier": "uk.chrisj.films.desktop",
  "build": { "frontendDist": "../dist" },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Film Index",
        "url": "https://films.chrisj.uk",
        "width": 1360,
        "height": 860
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
