# Copy this file to .env and fill in whichever integrations you want. The app
# works without them (typographic posters + rankings, and an inactive Download
# button), but these settings enable metadata and Radarr downloads.

# TMDB (posters, backdrops, cast photos, trailers) — free key:
#   https://www.themoviedb.org/settings/api   (use the v3 "API Key")
TSPDT_TMDB_KEY=

# OMDb (IMDb rating & votes, Rotten Tomatoes, Metacritic, plot, awards, box office)
#   http://www.omdbapi.com/apikey.aspx   (free tier: 1,000 requests/day)
TSPDT_OMDB_KEY=

# Radarr — all four values are required for the Download button.
# URL: the address Radarr has from this app's server/container. Include Radarr's
# URL base when it has one (for example, http://radarr:7878/radarr).
# API key: Radarr -> Settings -> General -> Security.
# Root folder: the exact movie-library path as Radarr sees it.
# Quality profile: numeric id from GET /api/v3/qualityprofile in Radarr.
RADARR_URL=
RADARR_API_KEY=
RADARR_ROOT_FOLDER=
RADARR_QUALITY_PROFILE_ID=

# Optional Prowlarr fallback for the release picker. Radarr searches indexers on
# TMDB's year (which it owns and won't let you override), so films whose release
# year differs from the year releases are tagged with find nothing. With Prowlarr
# set, the picker falls back to a text search on the catalogue year and pushes
# the chosen release back through Radarr (so it still imports/renames).
# URL defaults to the in-stack address (http://prowlarr:9696/prowlarr); usually
# you only need the API key (Prowlarr -> Settings -> General -> Security).
PROWLARR_URL=
PROWLARR_API_KEY=
